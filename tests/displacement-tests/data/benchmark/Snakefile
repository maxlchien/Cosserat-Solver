SPECFEM_BIN = "/home/mc7656/SPECFEMPP/bin/release-cuda/specfem 3d"
MESHFEM_BIN = "/home/mc7656/SPECFEMPP/bin/release-cuda/xmeshfem3D"
FOURIER_BIN = "/home/mc7656/experiments/Cosserat-Solver-3D/Cosserat-Solver"

rule all:
    input:
        # summary_plot=expand("OUTPUT_FILES/{channel}_plot.png", channel=["displacement", "rotation"]),
        traces=expand(
            "OUTPUT_FILES/{network_name}.{station_name}.S2.{component}.{extension}",
            station_name=["S0001", "S0002", "S0003", "S0004", "S0005"],# ,"S0005", "S0006", "S0007", "S0008", "S0009"],
            network_name=["AA"],
            component=["BXX", "BXY", "BXZ"],
            extension=["semr", "semd"],
        ),
    localrule: True


rule run_solver:
    input:
        params="params.yaml",
    output:
        traces=rules.all.input.traces,
    localrule: True
    shell:
        """
            uv pip install {FOURIER_BIN}
            uv run cosserat-solver --yaml {input.params} --o OUTPUT_FILES --use-python-backend
        """


